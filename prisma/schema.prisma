generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CASHIER
  MANAGER
  CLIENT
}

enum OrderChannel {
  ONLINE
  POS
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
  MIXED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum InventoryMovementType {
  OPENING_STOCK
  PURCHASE
  SALE
  RETURN_IN
  RETURN_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  WASTE
  TRANSFER_IN
  TRANSFER_OUT
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum CashMovementType {
  OPENING_FLOAT
  SALE_IN
  REFUND_OUT
  CASH_IN
  CASH_OUT
  CLOSING
}

enum SyncStatus {
  PENDING
  PROCESSING
  SYNCED
  FAILED
}

model User {
  id            String      @id @default(cuid())
  fullName      String
  email         String?     @unique
  phone         String?     @unique
  passwordHash  String
  role          Role        @default(CASHIER)
  isActive      Boolean     @default(true)
  loginAttempts Int         @default(0)
  lockUntil     DateTime?

  ordersCreated Order[]     @relation("OrderCreatedBy")
  posSessions   PosSession[]
  cashMovements CashMovement[]
  inventoryMoves InventoryMovement[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([role, isActive])
}

model Customer {
  id            String            @id @default(cuid())
  fullName      String
  phone         String?           @unique
  email         String?
  notes         String?

  addresses     CustomerAddress[]
  orders        Order[]

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([fullName])
}

model CustomerAddress {
  id            String      @id @default(cuid())
  customerId    String
  label         String?
  city          String
  district      String?
  street        String?
  buildingNo    String?
  floor         String?
  apartmentNo   String?
  latitude      Decimal?    @db.Decimal(10, 7)
  longitude     Decimal?    @db.Decimal(10, 7)
  isDefault     Boolean     @default(false)

  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders        Order[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([customerId, isDefault])
}

model Category {
  id            String      @id @default(cuid())
  nameAr        String
  nameEn        String?
  slug          String      @unique
  parentId      String?
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)

  parent        Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children      Category[]  @relation("CategoryTree")
  products      Product[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([parentId, isActive])
}

model Product {
  id                 String               @id @default(cuid())
  sku                String               @unique
  nameAr             String
  nameEn             String?
  descriptionAr      String?
  descriptionEn      String?
  brand              String?
  imageUrl           String?
  isActive           Boolean              @default(true)

  costPrice          Decimal              @db.Decimal(12, 3)
  salePrice          Decimal              @db.Decimal(12, 3)
  taxRatePercent     Decimal              @default(0) @db.Decimal(5, 2)
  priceIncludesTax   Boolean              @default(false)

  stockQty           Decimal              @default(0) @db.Decimal(12, 3)
  lowStockThreshold  Decimal              @default(0) @db.Decimal(12, 3)
  unit               String               @default("pcs")

  categoryId         String?
  category           Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  barcodes           ProductBarcode[]
  orderItems         OrderItem[]
  inventoryMoves     InventoryMovement[]
  stockAlerts        StockAlert[]

  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([nameAr, isActive])
  @@index([categoryId, isActive])
  @@index([stockQty])
}

model ProductBarcode {
  id            String    @id @default(cuid())
  productId     String
  code          String    @unique
  isPrimary     Boolean   @default(false)

  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())

  @@index([productId, isPrimary])
}

model Order {
  id                 String           @id @default(cuid())
  orderNumber        String           @unique
  channel            OrderChannel
  status             OrderStatus      @default(PENDING)

  customerId         String?
  addressId          String?
  createdByUserId    String?

  subtotal           Decimal          @db.Decimal(12, 3)
  discountType       DiscountType?
  discountValue      Decimal?         @db.Decimal(12, 3)
  discountAmount     Decimal          @default(0) @db.Decimal(12, 3)
  taxAmount          Decimal          @default(0) @db.Decimal(12, 3)
  shippingFee        Decimal          @default(0) @db.Decimal(12, 3)
  totalAmount        Decimal          @db.Decimal(12, 3)

  paymentMethod      PaymentMethod?
  paymentStatus      PaymentStatus    @default(UNPAID)
  paidAmount         Decimal          @default(0) @db.Decimal(12, 3)
  changeAmount       Decimal          @default(0) @db.Decimal(12, 3)

  notes              String?
  canceledReason     String?
  completedAt        DateTime?
  canceledAt         DateTime?

  customer           Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  address            CustomerAddress? @relation(fields: [addressId], references: [id], onDelete: SetNull)
  createdBy          User?            @relation("OrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  posSession         PosSession?
  inventoryMoves     InventoryMovement[]

  receipts           Receipt[]
  syncEvents         OfflineSyncEvent[]

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([channel, status, createdAt])
  @@index([customerId, createdAt])
  @@index([createdByUserId, createdAt])
}

model OrderItem {
  id                 String      @id @default(cuid())
  orderId            String
  productId          String

  quantity           Decimal     @db.Decimal(12, 3)
  unitPrice          Decimal     @db.Decimal(12, 3)
  costAtSale         Decimal     @db.Decimal(12, 3)
  discountAmount     Decimal     @default(0) @db.Decimal(12, 3)
  taxAmount          Decimal     @default(0) @db.Decimal(12, 3)
  lineTotal          Decimal     @db.Decimal(12, 3)

  order              Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt          DateTime    @default(now())

  @@index([orderId])
  @@index([productId])
}

model InventoryMovement {
  id                 String                @id @default(cuid())
  productId          String
  type               InventoryMovementType

  quantity           Decimal               @db.Decimal(12, 3)
  unitCost           Decimal?              @db.Decimal(12, 3)
  note               String?

  referenceOrderId   String?
  createdByUserId    String?

  product            Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  referenceOrder     Order?                @relation(fields: [referenceOrderId], references: [id], onDelete: SetNull)
  createdBy          User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt          DateTime              @default(now())

  @@index([productId, createdAt])
  @@index([type, createdAt])
}

model StockAlert {
  id                 String      @id @default(cuid())
  productId          String
  triggeredAtQty     Decimal     @db.Decimal(12, 3)
  resolved           Boolean     @default(false)
  resolvedAt         DateTime?

  product            Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt          DateTime    @default(now())

  @@index([productId, resolved, createdAt])
}

model PosSession {
  id                 String      @id @default(cuid())
  sessionNumber      String      @unique
  openedByUserId     String
  orderId            String?     @unique

  openedAt           DateTime    @default(now())
  closedAt           DateTime?
  openingFloat       Decimal     @default(0) @db.Decimal(12, 3)
  closingAmount      Decimal?    @db.Decimal(12, 3)
  expectedAmount     Decimal?    @db.Decimal(12, 3)
  differenceAmount   Decimal?    @db.Decimal(12, 3)

  openedBy           User        @relation(fields: [openedByUserId], references: [id], onDelete: Restrict)
  order              Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  cashMovements      CashMovement[]

  @@index([openedByUserId, openedAt])
}

model CashMovement {
  id                 String            @id @default(cuid())
  sessionId          String
  userId             String?
  type               CashMovementType
  amount             Decimal           @db.Decimal(12, 3)
  note               String?

  session            PosSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user               User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt          DateTime          @default(now())

  @@index([sessionId, type, createdAt])
}

model Receipt {
  id                 String      @id @default(cuid())
  orderId            String
  receiptNumber      String      @unique
  printableHtml      String?
  payloadJson        Json?
  printedAt          DateTime?
  printerName        String?

  order              Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt          DateTime    @default(now())

  @@index([orderId, createdAt])
}

model OfflineSyncEvent {
  id                 String      @id @default(cuid())
  orderId            String?
  entityType         String
  localEntityId      String
  deviceId           String
  payloadJson        Json
  status             SyncStatus  @default(PENDING)
  retryCount         Int         @default(0)
  lastError          String?

  order              Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([status, createdAt])
  @@index([deviceId, status])
}
